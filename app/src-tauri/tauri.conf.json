{
  "productName": "accountability-app",
  "version": "1.0.0",
  "identifier": "com.accountability.reminder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Accountability Audit",
        "width": 600,
        "height": 680,
        "decorations": false,
        "alwaysOnTop": true,
        "fullscreen": false,
        "maximizable": false,
        "resizable": true,
        "center": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}